{
  "name": "sshcommander",
  "version": "1.0.0",
  "description": "SSH terminal UI with workspace management and remote file editing",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:server && npm run build:client",
    "dev:server": "tsx watch src/main.ts",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "test:ssh-server": "tsx test/ssh-server.ts",
    "start": "node dist/main.js"
  },
  "keywords": [
    "ssh",
    "terminal",
    "workspace"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "node-pty": "^0.10.1",
    "open": "^11.0.0",
    "socket.io": "^4.5.4",
    "ssh2": "^1.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.15.5",
    "concurrently": "^8.0.1",
    "tsx": "^4.1.0",
    "typescript": "^5.0.0"
  }
}
