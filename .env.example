# sshCommander environment example
# Copy this file to .env and adjust values.

# Shell used for local terminal sessions (optional)
SHELL=/bin/zsh

# SCP chunk size
SSH_COMMANDER_UPLOAD_CHUNK_SIZE=4096

# Preferred editor for `sshCommander edit`.
# This should be a blocking command so upload happens on close.

# SSH_COMMANDER_EDITOR takes precedence over EDITOR and VISUAL.
# SSH_COMMANDER_EDITOR="nano"
# SSH_COMMANDER_EDITOR="vim"
# SSH_COMMANDER_EDITOR="nvim"
# SSH_COMMANDER_EDITOR="micro"
# SSH_COMMANDER_EDITOR="code --wait"
# SSH_COMMANDER_EDITOR="codium --wait"
# SSH_COMMANDER_EDITOR="kate --block"
# SSH_COMMANDER_EDITOR="subl -w"
# SSH_COMMANDER_EDITOR="gedit --wait"

# Generic editor fallback conventions (optional)
# EDITOR="nano"
# VISUAL="nvim"
